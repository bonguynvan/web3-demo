# TradingDek environment variables.
#
# Vite only exposes vars prefixed with VITE_ to client code. Any var
# without that prefix is build-script-only and never lands in the
# bundle. Copy this file to .env and fill in the values you need.
# All vars are optional — the app runs without any of them, falling
# back to public venue endpoints and localStorage persistence.

# ─── Feedback widget ──────────────────────────────────────────────────────
# Email address the floating "Send feedback" button opens a mailto to.
# Defaults to feedback@tradingdek.com when unset.
VITE_FEEDBACK_EMAIL=

# ─── Error reporting ──────────────────────────────────────────────────────
# Endpoint URL that accepts POST { kind, message, stack, route, ua,
# deviceId, at } from the browser. Works with any HTTP collector
# (Sentry, Logflare, Cloudflare Workers, a custom Lambda). When unset,
# captured errors go to the console only — never leave the browser.
VITE_ERROR_REPORT_ENDPOINT=

# ─── Analytics (Plausible-compatible) ─────────────────────────────────────
# Your site domain as registered in Plausible (e.g. tradingdek.com). When
# set, the official Plausible script tag is injected at runtime; pageviews
# are auto-tracked via the History API (no cookies, no PII). Unset = no
# analytics script is loaded.
VITE_PLAUSIBLE_DOMAIN=

# Optional override for the Plausible script source. Default is the
# official hosted script. Override to self-host or to use a custom proxy
# (e.g. https://plausible.your-domain.com/js/script.js).
VITE_PLAUSIBLE_SCRIPT=

# ─── Hyperliquid trading (Phase 2d, not yet wired) ────────────────────────
# Your wallet address — receives ~0.01% builder-code rebate per trade
# routed through the UI once wallet trading lands.
VITE_HYPERLIQUID_BUILDER_CODE=

# mainnet | testnet — controls which Hyperliquid REST/WS host is used.
# Default mainnet.
VITE_HYPERLIQUID_NETWORK=mainnet

# ─── News signal source (CryptoPanic) ─────────────────────────────────────
# Free tier auth token from https://cryptopanic.com/developers/api/
# When set, important sentiment-leaning headlines for tracked markets fire
# as news signals in the Signals tab. Unset = source stays dormant.
VITE_CRYPTOPANIC_TOKEN=

# ─── On-chain whale wallets (Hyperliquid only) ────────────────────────────
# Comma-separated list of Hyperliquid wallet addresses to track. When any
# tracked address opens a perp position above $50k notional, a whale-wallet
# signal fires. Hyperliquid's userFills endpoint is fully public on-chain
# data — no API key needed beyond knowing which addresses to follow.
VITE_HL_WHALE_WALLETS=

# ─── Build-time only (NOT bundled) ────────────────────────────────────────
# Without the VITE_ prefix these never end up in the client bundle.
# They're consumed by scripts/ at build time.

# fal.ai API key. Used by `pnpm gen:assets` to regenerate hero/og/empty-
# state images from Flux Pro 1.1 Ultra. Generate one at
# https://fal.ai/dashboard/keys and pass via the env when running:
#   FAL_KEY=fal_xxx pnpm gen:assets
# Never commit a real value here.
FAL_KEY=
