# ─── @perp-dex/contracts ───────────────────────────────────────────────────
# Foundry/Forge smart contracts for the perp DEX.
#
# For LOCAL development (Anvil): no .env needed — everything is hardcoded
# in the deploy script with Anvil's default accounts.
#
# For TESTNET/MAINNET deployment: copy this to .env and fill in values,
# then use `source .env && forge script ...`

# ─── Deployer ─────────────────────────────────────────────────────────────
# Private key of the account that deploys contracts.
# For Anvil: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# For testnet: use a funded testnet account (NEVER commit real keys!)
DEPLOYER_PRIVATE_KEY=

# ─── Network ──────────────────────────────────────────────────────────────
# RPC endpoint for the target chain.
# Anvil:          http://127.0.0.1:8545
# Arbitrum Sepolia: https://sepolia-rollup.arbitrum.io/rpc
# Arbitrum One:   https://arb1.arbitrum.io/rpc (or your Alchemy/Infura URL)
RPC_URL=http://127.0.0.1:8545

# Chain ID (used by forge script --chain-id)
# Anvil: 31337 | Arbitrum Sepolia: 421614 | Arbitrum One: 42161
CHAIN_ID=31337

# ─── Etherscan Verification (optional) ────────────────────────────────────
# Required only if you want to verify contracts on Arbiscan after deployment.
# Get a free API key at https://arbiscan.io/myapikey
ETHERSCAN_API_KEY=
