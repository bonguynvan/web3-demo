# ─── @perp-dex/keepers ─────────────────────────────────────────────────────
# Keeper bots (liquidator + price updater) for the perp DEX.
#
# NOTE: tsx does NOT auto-load .env files. For local dev, all vars have
# working Anvil defaults — you can skip this file entirely.
#
# To use .env:
#   1. pnpm add dotenv
#   2. Add `import 'dotenv/config'` at the top of src/liquidator.ts
#      and src/price-updater.ts
#   3. Copy this file to .env and fill in values

# ─── Network ──────────────────────────────────────────────────────────────
RPC_URL=http://127.0.0.1:8545

# ─── Keeper Wallet ────────────────────────────────────────────────────────
# Private key of the keeper account that executes liquidations.
# Default = Anvil account 0 (DO NOT use real keys here for production!)
KEEPER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ─── Contract Addresses ───────────────────────────────────────────────────
# Auto-detected from src/addresses.json (written by deploy script).
# Only override these if deploying to a non-Anvil chain.

# USDC_ADDRESS=
# WETH_ADDRESS=
# WBTC_ADDRESS=
# PRICE_FEED_ADDRESS=
# VAULT_ADDRESS=
# POSITION_MANAGER_ADDRESS=
# ROUTER_ADDRESS=
# ETH_ORACLE_ADDRESS=
# BTC_ORACLE_ADDRESS=
