# ─── @perp-dex/server ──────────────────────────────────────────────────────
# Server reads env vars directly from process.env. tsx does NOT auto-load
# .env files, so for local dev set them in your shell or skip the file
# entirely (every var has a working Anvil default).
#
# For testnet deploy:
#   1. Add `dotenv` to package.json: pnpm add dotenv
#   2. Add `import 'dotenv/config'` at the top of src/index.ts
#   3. Copy this file to .env and fill in your testnet values
#
# Or set them via your hosting provider's env config (Railway, Fly.io, etc.)

# ─── Network ───────────────────────────────────────────────────────────────

# RPC endpoint to read from
RPC_URL=http://127.0.0.1:8545

# HTTP API port
PORT=3001

# WebSocket server port (separate from HTTP)
WS_PORT=3002

# ─── Contract addresses ────────────────────────────────────────────────────
# Defaults come from packages/contracts/typechain/LOCALHOST_ADDRESSES.
# Override these when deploying to a non-Anvil chain.

# USDC_ADDRESS=
# WETH_ADDRESS=
# WBTC_ADDRESS=
# PRICE_FEED_ADDRESS=
# VAULT_ADDRESS=
# POSITION_MANAGER_ADDRESS=
# ROUTER_ADDRESS=
# PLP_ADDRESS=
# ETH_ORACLE_ADDRESS=
# BTC_ORACLE_ADDRESS=
