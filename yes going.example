# ─── Frontend (Vite) ───────────────────────────────────────────────────────
# Vite only exposes vars prefixed with VITE_ to client code.
# Copy this file to .env and edit as needed.

# REST API base URL (no trailing slash)
VITE_API_URL=http://localhost:3001

# WebSocket server URL (price + trade event channels)
VITE_WS_URL=ws://localhost:3002

# ─── Spot Trading (Arbitrum) ───────────────────────────────────────────────
# Required for spot swap via 0x API. Get a free key at https://0x.org
VITE_0X_API_KEY=

# Optional: custom Arbitrum RPC (defaults to public endpoint if empty)
VITE_ARBITRUM_RPC_URL=
